<?php
// Enable CORS for form submissions
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: POST, OPTIONS');
header('Access-Control-Allow-Headers: Content-Type');
header('Content-Type: application/json');

// Handle preflight requests
if ($_SERVER['REQUEST_METHOD'] === 'OPTIONS') {
	http_response_code(200);
	exit();
}

// Only accept POST requests
if ($_SERVER['REQUEST_METHOD'] !== 'POST') {
	http_response_code(405);
	echo json_encode(['error' => 'Method not allowed']);
	exit();
}

// Load PHPMailer
require 'phpmailer/src/Exception.php';
require 'phpmailer/src/PHPMailer.php';
require 'phpmailer/src/SMTP.php';

use PHPMailer\PHPMailer\PHPMailer;
use PHPMailer\PHPMailer\Exception;

// Get form data
$name = isset($_POST['name']) ? trim($_POST['name']) : '';
$email = isset($_POST['email']) ? trim($_POST['email']) : '';
$phone = isset($_POST['phone']) ? trim($_POST['phone']) : '';
$fabric_type = isset($_POST['fabric_type']) ? trim($_POST['fabric_type']) : '';
$message = isset($_POST['message']) ? trim($_POST['message']) : '';

// Validate required fields
if (!$name || !$email || !$phone) {
	http_response_code(400);
	echo json_encode(['error' => 'Missing required fields']);
	exit();
}

// Validate email format
if (!filter_var($email, FILTER_VALIDATE_EMAIL)) {
	http_response_code(400);
	echo json_encode(['error' => 'Invalid email address']);
	exit();
}

// Load configuration from .env
$env_file = __DIR__ . '/.env';
if (!file_exists($env_file)) {
	http_response_code(500);
	echo json_encode(['error' => 'Configuration missing. Please set up .env file.']);
	exit();
}

$env = parse_ini_file($env_file);

$gmail_user = $env['GMAIL_USER'] ?? '';
$gmail_password = $env['GMAIL_PASSWORD'] ?? '';
$recipient_email = $env['RECIPIENT_EMAIL'] ?? '';

if (!$gmail_user || !$gmail_password || !$recipient_email) {
	http_response_code(500);
	echo json_encode(['error' => 'Server configuration error']);
	exit();
}

try {
	$mail = new PHPMailer(true);

	// Server settings
	$mail->isSMTP();
	$mail->Host = 'smtp.gmail.com';
	$mail->SMTPAuth = true;
	$mail->Username = $gmail_user;
	$mail->Password = $gmail_password;
	$mail->SMTPSecure = PHPMailer::ENCRYPTION_STARTTLS;
	$mail->Port = 587;

	// Recipients
	$mail->setFrom($gmail_user, 'SoftNest Upholstery Cleaning');
	$mail->addAddress($recipient_email, 'SoftNest');
	$mail->addReplyTo($email, $name);

	// Content
	$mail->isHTML(true);
	$mail->Subject = "New Service Request from {$name}";

	// Load email template
	$email_template_file = __DIR__ . '/email-template.html';
	if (file_exists($email_template_file)) {
		$email_body = file_get_contents($email_template_file);
		// Replace placeholders
		$email_body = str_replace(
			['{NAME}', '{EMAIL}', '{PHONE}', '{FABRIC_TYPE}', '{MESSAGE}'],
			[$name, $email, $phone, $fabric_type, nl2br(htmlspecialchars($message))],
			$email_body
		);
	} else {
		// Fallback plain text email if template not found
		$email_body = "<strong>New Service Request</strong><br><br>";
		$email_body .= "<b>Name:</b> " . htmlspecialchars($name) . "<br>";
		$email_body .= "<b>Email:</b> " . htmlspecialchars($email) . "<br>";
		$email_body .= "<b>Phone:</b> " . htmlspecialchars($phone) . "<br>";
		$email_body .= "<b>Fabric/Sofa Style:</b> " . htmlspecialchars($fabric_type) . "<br>";
		$email_body .= "<b>Cleaning Challenges:</b> " . nl2br(htmlspecialchars($message)) . "<br>";
	}

	$mail->Body = $email_body;

	// Send email
	$mail->send();

	// Send confirmation email to customer
	$mail->clearAddresses();
	$mail->addAddress($email, $name);
	$mail->Subject = "We received your SoftNest cleaning request";
	$mail->Body = "<h2>Thank you, {$name}!</h2>";
	$mail->Body .= "<p>We've received your upholstery cleaning request and will contact you shortly.</p>";
	$mail->Body .= "<p><strong>SoftNest Fabric Care</strong><br>";
	$mail->Body .= "Phone: (416) 727-0287 | (416) 726-4907<br>";
	$mail->Body .= "Email: andrey.gta.services@gmail.com</p>";
	$mail->send();

	http_response_code(200);
	echo json_encode(['success' => true, 'message' => 'Your details have been submitted successfully. Our specialist will contact you soon.']);

} catch (Exception $e) {
	http_response_code(500);
	echo json_encode(['error' => 'Failed to send email: ' . $mail->ErrorInfo]);
}
?>
